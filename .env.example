# Firebase project settings
FIREBASE_PROJECT_ID=zooco-90220

# Option 1: Use a local service account JSON file.
# Create serviceAccountKey.json in the project root and set this path.
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json

# Option 2: Use the JSON content directly in an environment variable.
# FIREBASE_ADMIN_CREDENTIALS={"type":"service_account", ...}

# Supabase Backend Settings (Used by server.ts)
SUPABASE_URL=https://apvzpyzvawdxwtvgpunl.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_server_only_service_role_key_here
SUPABASE_STORAGE_BUCKET=images

# Supabase Frontend Settings (Used by src/pages/supabase.ts)
VITE_SUPABASE_URL=https://apvzpyzvawdxwtvgpunl.supabase.co
VITE_SUPABASE_ANON_KEY=your_public_anon_key_here

# Optional: local dev server port
PORT=3000
